mainmenu "HouseOS Configuration"

menu "Image build"

config IMG_SECTORS
    int "Disk image size (sectors)"
    default 131072

menu "Bootloader"

config BOOT_DYNAMIC_PARAMS
    bool "Enable dynamic boot parameters from /dev/bootloader"
    default y

config BOOT_DEBUG
    bool "Enable stage2 debug messages"
    default n

config BOOT_FLAGS_EXTRA
    hex "Extra boot flags bitmask"
    default 0x0

endmenu

menu "Memory layout (advanced)"

config INITRAMFS_LOAD_ADDR
    hex "Initramfs load address"
    default 0x00100000

endmenu

endmenu

menu "Kernel"

menu "File systems"

