    bool "PS/2 mouse"
    default y

endmenu

menu "Graphics"

choice
    prompt "Graphics backend"
    default GRAPHICS_BACKEND_VGA

config GRAPHICS_BACKEND_VGA
    bool "VGA text mode"

config GRAPHICS_BACKEND_VESA
    bool "VESA framebuffer"

endchoice

config GRAPHICS_VGA_MODE
    hex "VGA mode"
    depends on GRAPHICS_BACKEND_VGA
    default 0x03

config GRAPHICS_VESA_MODE
    hex "VESA mode"
    depends on GRAPHICS_BACKEND_VESA
    default 0x0118

choice
    prompt "VESA rotation"
    depends on GRAPHICS_BACKEND_VESA
    default VESA_ROTATION_0

config VESA_ROTATION_0
    bool "0 degrees"

config VESA_ROTATION_90
    bool "90 degrees"

config VESA_ROTATION_180
    bool "180 degrees"

config VESA_ROTATION_270
    bool "270 degrees"

endchoice

config GSHELL
    bool "Graphical shell"
    default n

endmenu

endmenu

